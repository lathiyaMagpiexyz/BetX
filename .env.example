# =============================================================================
# FairDrop — Environment variables
# Copy to .env.local and fill in real values for development.
# Defaults target BSC testnet (chain 97) — flip NEXT_PUBLIC_CHAIN_ID for others.
# =============================================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Web3 (frontend) ---
# 56 = BSC mainnet, 97 = BSC testnet, 8453 = Base mainnet, 84532 = Base Sepolia
NEXT_PUBLIC_CHAIN_ID=97
# Public BSC testnet RPC — no auth required. Swap for an Alchemy/QuickNode URL for higher rate limits.
NEXT_PUBLIC_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
# Get from https://cloud.walletconnect.com/ — free, takes 30 seconds.
# Leave as placeholder for demo mode (MetaMask injected only, no QR/mobile wallets).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=placeholder-walletconnect-id
# Set after `forge script script/Deploy.s.sol --rpc-url bsc_testnet --broadcast`.
NEXT_PUBLIC_GIVEAWAY_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
# Stable token entrants pay to enter every giveaway. Must match ENTRY_TOKEN_ADDRESS below.
#
# Mainnet references:
#   BSC mainnet USDT:    0x55d398326f99059fF775485246999027B3197955 (18 decimals, symbol USDT)
#   Base mainnet USDC:   0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913 (6 decimals,  symbol USDC)
#
# BSC testnet has no canonical USDT — easiest path is to deploy your own ERC20Mock via
# `forge create lib/openzeppelin-contracts/contracts/mocks/token/ERC20Mock.sol:ERC20Mock` and
# paste the resulting address below. See README for the exact command.
NEXT_PUBLIC_ENTRY_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ENTRY_TOKEN_DECIMALS=18
NEXT_PUBLIC_ENTRY_TOKEN_SYMBOL=tUSDT

# --- Web3 (server / contract deployment) ---
# DEPLOYER_PRIVATE_KEY: only used by `forge script` — never imported into Next.js code.
# This is the BSC testnet wallet you'll use to deploy. NEVER commit a real key.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
# Required by Deploy.s.sol — passed into GiveawayFactory's constructor as the entry token.
# Must match NEXT_PUBLIC_ENTRY_TOKEN_ADDRESS above.
ENTRY_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
# Optional — used for contract verification on testnet.bscscan.com. Free at bscscan.com/myapikey.
BSCSCAN_API_KEY=YOUR_BSCSCAN_API_KEY

# --- Indexer (Ponder, optional) ---
# Only needed if you want a live-indexed /giveaways list. Without this, the frontend
# falls back to demo fixtures (3 sample giveaways).
PONDER_RPC_URL_BSC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
PONDER_DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
PONDER_START_BLOCK=0

# --- Database (Supabase, optional) ---
# Only needed if Ponder is running and writing here. Otherwise leave as placeholders.
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key
SUPABASE_SERVICE_ROLE_KEY=placeholder-service-role-key

# --- Analytics (PostHog, optional) ---
NEXT_PUBLIC_POSTHOG_KEY=placeholder-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
